#!/bin/sh
set -eu

REPO_API="${SFE_RELEASE_API:-https://api.github.com/repos/changfengpro/SSH-file-editor/releases/latest}"
SFE_CURL_USER_AGENT="${SFE_CURL_USER_AGENT:-sfe-upgrade}"
SFE_PYTHON="${SFE_PYTHON:-/usr/lib/sfe/python/bin/python3}"

usage() {
    cat <<'USAGE'
Usage: sfe-upgrade

Download the latest sfe Debian package from GitHub Releases and install it
with dpkg. Requires curl, sha256sum, dpkg, and sudo.
USAGE
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
    echo "sfe-upgrade: curl is required" >&2
    exit 1
fi

if ! command -v dpkg >/dev/null 2>&1; then
    echo "sfe-upgrade: dpkg is required" >&2
    exit 1
fi

SFE_ARCH="${SFE_ARCH:-$(dpkg --print-architecture)}"
case "$SFE_ARCH" in
    amd64|arm64)
        ;;
    *)
        echo "sfe-upgrade: unsupported architecture: $SFE_ARCH" >&2
        echo "sfe-upgrade: supported architectures are amd64 and arm64" >&2
        exit 1
        ;;
esac
SFE_LATEST_DEB_URL="${SFE_LATEST_DEB_URL:-https://github.com/changfengpro/SSH-file-editor/releases/latest/download/sfe_latest_${SFE_ARCH}.deb}"

install_deb() {
    deb="$1"
    echo "Installing ${deb##*/}"
    sudo dpkg -i "$deb"
}

tmpdir=$(mktemp -d)
cleanup() {
    rm -rf "$tmpdir"
}
trap cleanup EXIT INT TERM

deb_name=${SFE_LATEST_DEB_URL##*/}
deb_path="$tmpdir/$deb_name"

echo "Downloading $deb_name"
echo "URL: $SFE_LATEST_DEB_URL"
if curl -fL \
    -H "User-Agent: $SFE_CURL_USER_AGENT" \
    "$SFE_LATEST_DEB_URL" -o "$deb_path"; then
    echo "SHA256:"
    sha256sum "$deb_path"

    install_deb "$deb_path"
    exit 0
fi

echo "sfe-upgrade: direct latest package download failed; trying GitHub release API" >&2

release_json="$tmpdir/release.json"
if ! curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    -H "User-Agent: $SFE_CURL_USER_AGENT" \
    "$REPO_API" -o "$release_json"; then
    cat >&2 <<'ERROR'
sfe-upgrade: failed to fetch the latest release metadata from GitHub.
Check your network/proxy settings, or try again later if GitHub rate limited
the request. You can also download the .deb from the GitHub Releases page.
ERROR
    exit 1
fi

deb_url=$("$SFE_PYTHON" - "$release_json" "$SFE_ARCH" <<'PY'
import json
import sys

release_path = sys.argv[1]
arch = sys.argv[2]
name = f"sfe_latest_{arch}.deb"

with open(release_path, encoding="utf-8") as fh:
    release = json.load(fh)

for asset in release.get("assets", []):
    asset_name = asset.get("name", "")
    url = asset.get("browser_download_url", "")
    if asset_name == name and url:
        print(url)
        break
else:
    raise SystemExit(f"no sfe Debian package asset found in latest release for {arch}")
PY
)

deb_name=${deb_url##*/}
deb_path="$tmpdir/$deb_name"

echo "Downloading $deb_name"
echo "URL: $deb_url"
if ! curl -fL \
    -H "User-Agent: $SFE_CURL_USER_AGENT" \
    "$deb_url" -o "$deb_path"; then
    echo "sfe-upgrade: failed to download $deb_name" >&2
    exit 1
fi

echo "SHA256:"
sha256sum "$deb_path"

install_deb "$deb_path"
